}
`;

exports[`inheritance grouping > does not duplicate parent name when multiple children extend the same parent 1`] = `
Map {
  "Parent" => {
    "constructorString": "class P{}",
    "name": "Parent",
    "order": 0,
    "properties": [
      {
        "name": "shared",
        "type": PrimitiveType {
          "kind": "string",
        },
      },
    ],
  },
  "ChildA" => {
    "constructorString": "class CA{}",
    "extendedConstructorString": "class P{}",
    "extends": "Parent",
    "name": "ChildA",
    "order": 1,
    "properties": [
      {
        "name": "a",
        "type": PrimitiveType {
          "kind": "string",
        },
      },
    ],
  },
  "ChildB" => {
    "constructorString": "class CB{}",
    "extendedConstructorString": "class P{}",
    "extends": "Parent",
    "name": "ChildB",
    "order": 2,
    "properties": [
      {
        "name": "b",
        "type": PrimitiveType {
          "kind": "string",
        },
      },
    ],
  },
}
`;


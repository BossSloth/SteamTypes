// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`inheritance grouping > collapses inheritance group whose members all share the same constructor 1`] = `
Map {
  "A" => {
    "constructorString": "class Same{}",
    "extendedConstructorString": "class Parent{}",
    "extends": undefined,
    "name": "A",
    "nameCounter": undefined,
    "order": 0,
    "properties": [
      {
        "name": "x",
        "optional": false,
        "type": PrimitiveType {
          "kind": "string",
        },
      },
    ],
  },
}
`;

exports[`inheritance grouping > discards inheritance groups that contain only a single interface 1`] = `
Map {

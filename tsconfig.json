{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "EsNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "baseUrl": ".",
    "paths": {
      "*": ["./src/*"],
      "Global/*": ["./src/types/Global/*"],
      "Modules/*": ["./src/types/Modules/*"],
      "Protobufs/*": ["./src/types/Protobufs/*"],
      "shared/*": ["./src/types/shared/*"],
      "SteamClient/*": ["./src/types/SteamClient/*"],
      "SteamClient": ["./src/types/SteamClient/index"],
      "@Runtime/*": ["./src/Runtime/*"],
      "@Convert/*": ["./scripts/convert-to-typescript/*"],
      "@Compare/*": ["./scripts/compare-to-typescript/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
